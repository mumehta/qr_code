rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Deny everything not explicitly matched below.
    match /{document=**} {
      allow read, write: if false;
    }

    // Each authenticated user can only read and write their own QR history.
    match /users/{uid}/qrHistory/{docId} {
      allow read, delete: if request.auth != null && request.auth.uid == uid;

      allow create: if request.auth != null
        && request.auth.uid == uid
        // Must include exactly the four required fields.
        && request.resource.data.keys().hasAll(['content', 'type', 'label', 'createdAt'])
        // Field type constraints.
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.type in ['URL', 'Text', 'Contact']
        && request.resource.data.label is string;
    }
  }
}
